# -------------------------------------------------------
# Copy this file to .env and fill in ALL values before
# running the deploy script.
# -------------------------------------------------------

# Flask
FLASK_ENV=production
SECRET_KEY=CHANGE_ME_use_a_long_random_string_min_32_chars

# PostgreSQL  (deploy.sh creates this DB/user automatically)
DATABASE_URL=postgresql://hms_user:CHANGE_ME_DB_PASSWORD@localhost/hms_db

# Which hotel the PUBLIC booking website shows
# Set this to the hotel ID after your first login (usually 1)
NGENDA_HOTEL_ID=1

# Currency conversion (TZS to USD rate)
TZS_TO_USD=2500

# Restaurant POS tax rate (%)
DEFAULT_TAX_RATE=18
TAX_RATE_DISPLAY=18

# Email / SMTP
MAIL_SERVER=mail.ngendagroup.africa
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=hotels@ngendagroup.africa
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_DEFAULT_SENDER=Ngenda Hotel <hotels@ngendagroup.africa>
MAIL_HOTEL_EMAIL=hotels@ngendagroup.africa
